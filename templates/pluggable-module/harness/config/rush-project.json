{
    "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/rush-project.schema.json",
    "incrementalBuildIgnoredGlobs": [],
    "operationSettings": [
        {
            "operationName": "_phase:build",
            "outputFolderNames": ["dist"]
        },
        {
            "operationName": "_phase:validate",
            "outputFolderNames": []
        },
        {
            "operationName": "_phase:test",
            "outputFolderNames": []
        },
        {
            // The scaffolder-injected `_phase:pack-build` (see internalProfile.ts) builds the
            // harness shell into <app>-harness.tgz and copies the sibling module's federation
            // remote `../module/gdc-app-template-name-pluggable.tgz` in as <app>-remote.tgz —
            // both ADDed by the harness Dockerfile. The harness depends on its sibling module as
            // a workspace dep, so Rush runs the module's _phase:pack-build first. If that dep edge
            // is ever removed, the copy will fail with ENOENT — fix the dep, not the script.
            "operationName": "_phase:pack-build",
            "outputFolderNames": [],
            "disableBuildCacheForOperation": true
        },
        {
            "operationName": "_phase:publish-test-docker-images",
            "outputFolderNames": [],
            "disableBuildCacheForOperation": true
        }
    ]
}
