{
    "targets": [
        {
            "targetName": "gdc-app-template-name-module-unit-tests",
            "changeDirs": [
                {
                    "glob": "**/*",
                    "type": "fine-grained",
                    "filter": "**/*.test.ts*"
                }
            ]
        }
    ],
    "ignores": [
        "README.md",
        "readme.txt",
        ".oxlintrc.json",
        "eslint.config.ts",
        ".env.template",
        ".gitignore",
        ".dockerignore"
    ]
}
