{
    "name": "gdc-app-template-name-module",
    "version": "11.45.0-alpha.1",
    "private": true,
    "description": "{applicationTemplateTitle} pluggable application module",
    "license": "UNLICENSED",
    "author": {
        "name": "Stellar",
        "email": "stellar@gooddata.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gdc-ui/",
        "directory": "modules/gdc-app-template-name/module"
    },
    "type": "module",
    "sideEffects": false,
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "source": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./tsconfig.json": "./tsconfig.json"
    },
    "scripts": {
        "_phase:build": "npm run build-check",
        "_phase:validate": "npm run validate",
        "build": "npm-run-all -p build-check dist",
        "build-check": "tsgo",
        "clean": "../../../../common/scripts/clean-command-state.sh && rm -rf esm dist *.tgz *.log tsconfig.tsbuildinfo",
        "dev": "vite build && npm-run-all --parallel dev:build dev:serve",
        "dev:build": "vite build --watch",
        "dev:serve": "vite preview",
        "dist": "vite build",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --quiet && eslint .",
        "lint-fix": "oxlint . --quiet --fix && eslint . --fix",
        "validate": "npm run lint && npm run format-check"
    },
    "dependencies": {
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-pluggable-application-model": "workspace:*",
        "@gooddata/sdk-ui": "workspace:*",
        "@gooddata/sdk-ui-pluggable-application": "workspace:*",
        "@gooddata/util": "workspace:*",
        "lodash-es": "^4.17.23",
        "react-intl": "7.1.11"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@module-federation/vite": "1.16.11",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "24.12.0",
        "@types/react": "19.1.11",
        "@types/react-dom": "19.1.7",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "@vitejs/plugin-react": "6.0.2",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "happy-dom": "20.9.0",
        "jiti": "2.6.1",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "rolldown": "1.0.3",
        "sass": "1.70.0",
        "typescript": "5.9.3",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    }
}
