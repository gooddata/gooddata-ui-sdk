{
    "name": "@gooddata/create-pluggable-module",
    "version": "11.41.0-alpha.1",
    "description": "Scaffolder for GoodData pluggable applications. Invoked via `npm init @gooddata/pluggable-module`.",
    "license": "MIT",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "tools/create-pluggable-module"
    },
    "bin": {
        "create-pluggable-module": "./esm/index.js"
    },
    "files": [
        "esm/**/*.js",
        "esm/**/*.json",
        "esm/**/*.d.ts",
        "esm/**/*.map",
        "dist/templates/**"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./esm/index.js",
    "types": "./esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./esm/index.d.ts",
            "default": "./esm/index.js"
        }
    },
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:test": "npm run test-once",
        "_phase:validate": "npm run validate",
        "build": "npm-run-all -p build-check build-ts",
        "build-check": "tsgo",
        "build-ts": "tsgo -p tsconfig.build.json",
        "clean": "../../common/scripts/clean-command-state.sh && rm -rf ci dist esm coverage *.log tsconfig.tsbuildinfo",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --quiet && eslint src",
        "lint-fix": "oxlint . --quiet --fix && eslint src --fix",
        "postpack": "bash scripts/postpack-cleanup.sh",
        "prepack": "bash scripts/prepack-bundle-template.sh",
        "prepublishOnly": "npm run build",
        "test": "vitest watch",
        "test-once": "vitest run --passWithNoTests",
        "validate": "npm run lint && npm run format-check"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@types/node": "24.12.0",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-esm": "1.2.1",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-sonarjs": "3.0.6",
        "gdc-app-template-name-harness": "workspace:*",
        "gdc-app-template-name-module": "workspace:*",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "tslib": "2.8.1",
        "typescript": "5.9.3",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    },
    "engines": {
        "node": ">=24.12.0"
    }
}
