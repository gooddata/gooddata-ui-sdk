{
    "name": "@gooddata/sdk-ui-pluggable-host",
    "version": "11.46.0-alpha.1",
    "description": "GoodData SDK runtime for hosting pluggable applications — registry, loader, routing, platform context, default UI chrome",
    "license": "MIT",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "libs/sdk-ui-pluggable-host"
    },
    "files": [
        "esm/**/*.js",
        "esm/**/*.json",
        "esm/**/*.d.ts",
        "esm/**/*.map",
        "esm/**/*.css",
        "esm/**/*.scss",
        "esm/**/*.svg"
    ],
    "type": "module",
    "sideEffects": [
        "**/*.css",
        "**/*.scss"
    ],
    "browser": "./esm/index.js",
    "types": "./esm/index.d.ts",
    "exports": "./esm/index.js",
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:test": "npm run test-once",
        "_phase:validate": "npm run validate",
        "api-extractor": "mkdir -p api && [ -z \"${CI}\" ] && (api-extractor run -l) || (api-extractor run)",
        "build": "npm-run-all -p build-check build-ts && npm run copy-assets && npm run api-extractor",
        "build-check": "tsgo",
        "build-ts": "tsgo -p ./tsconfig.build.json",
        "clean": "../../common/scripts/clean-command-state.sh && rm -rf esm *.log",
        "copy-assets": "bash scripts/copy-assets.sh",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --quiet && eslint .",
        "lint-fix": "oxlint . --quiet --fix && eslint . --fix",
        "test": "vitest",
        "test-once": "vitest run",
        "validate": "npm run lint && npm run format-check"
    },
    "dependencies": {
        "@gooddata/sdk-backend-base": "workspace:*",
        "@gooddata/sdk-backend-spi": "workspace:*",
        "@gooddata/sdk-backend-tiger": "workspace:*",
        "@gooddata/sdk-embedding": "workspace:*",
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-pluggable-application-model": "workspace:*",
        "@gooddata/sdk-ui": "workspace:*",
        "@gooddata/sdk-ui-application-header": "workspace:*",
        "@gooddata/sdk-ui-ext": "workspace:*",
        "@gooddata/sdk-ui-gen-ai": "workspace:*",
        "@gooddata/sdk-ui-kit": "workspace:*",
        "@gooddata/sdk-ui-semantic-search": "workspace:*",
        "@gooddata/sdk-ui-theme-provider": "workspace:*",
        "@gooddata/util": "workspace:*",
        "@module-federation/runtime": "2.3.1",
        "lodash-es": "^4.17.23"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@microsoft/api-documenter": "^7.17.0",
        "@microsoft/api-extractor": "^7.55.2",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "24.12.0",
        "@types/react": "19.1.11",
        "@types/react-dom": "19.1.7",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "@vitest/coverage-v8": "4.1.8",
        "@vitest/eslint-plugin": "1.6.19",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "happy-dom": "20.9.0",
        "jiti": "2.6.1",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "react-intl": "7.1.11",
        "react-router": "^7.15.1",
        "rolldown": "1.0.3",
        "sass": "1.70.0",
        "tslib": "2.8.1",
        "typescript": "5.9.3",
        "vite": "8.0.16",
        "vitest": "4.1.8",
        "vitest-dom": "0.1.1"
    },
    "peerDependencies": {
        "react": ">=18.3.1",
        "react-dom": ">=18.3.1",
        "react-intl": ">=7",
        "react-router": ">=7"
    }
}
