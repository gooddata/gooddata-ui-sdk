{
    "name": "@gooddata/sdk-ui-web-components",
    "version": "11.49.0-alpha.1",
    "description": "GoodData Web Components wrapper for GoodData.UI",
    "license": "LicenseRef-LICENSE",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "libs/sdk-ui-web-components"
    },
    "files": [
        "esm/**/*.js",
        "esm/**/*.json",
        "esm/**/*.d.ts",
        "esm/**/*.map",
        "esm/**/*.svg",
        "esm/**/*.woff",
        "esm/**/*.woff2",
        "esm/**/*.eot",
        "esm/**/*.ttf",
        "bin/**/*.sh"
    ],
    "type": "module",
    "sideEffects": [
        "*.css",
        "*.svg",
        "**/autoAuth.*"
    ],
    "module": "./esm/index.js",
    "browser": "./esm/index.js",
    "types": "./esm/index.d.ts",
    "es2015": "./esm/index.js",
    "exports": "./esm/index.js",
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:pack-build": "tar -czf sdk-ui-web-components.tgz -C esm .",
        "_phase:publish-docker-images": "bash ../../../common/scripts/docker/publish-docker-image.sh",
        "_phase:publish-test-docker-images": "bash ../../../common/scripts/docker/publish-test-docker-image.sh",
        "_phase:test": "npm run test-once",
        "_phase:validate": "npm run validate",
        "api-extractor": "mkdir -p api && [ -z \"${CI}\" ] && (api-extractor run -l) || (api-extractor run)",
        "build": "npm-run-all -p build-check build-bundle build-declarations && npm run api-extractor",
        "build-bundle": "rm -rf esm && vite build --mode production",
        "build-check": "tsgo",
        "build-declarations": "rm -rf temp && tsgo -p tsconfig.build.json --outDir temp --emitDeclarationOnly",
        "build-dev": "vite build --mode development",
        "dep-cruiser": "depcruise --validate .dependency-cruiser.js --output-type err-long src/",
        "dev": "vite",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --quiet && eslint .",
        "lint-fix": "oxlint . --quiet --fix && eslint . --fix",
        "proxy": "node ./scripts/proxy.js",
        "test": "vitest watch",
        "test-once": "vitest run",
        "validate": "npm run lint && npm run dep-cruiser && npm run format-check"
    },
    "dependencies": {
        "@gooddata/sdk-backend-spi": "workspace:*",
        "@gooddata/sdk-backend-tiger": "workspace:*",
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-ui": "workspace:*",
        "@gooddata/sdk-ui-charts": "workspace:*",
        "@gooddata/sdk-ui-dashboard": "workspace:*",
        "@gooddata/sdk-ui-ext": "workspace:*",
        "@gooddata/sdk-ui-filters": "workspace:*",
        "@gooddata/sdk-ui-gen-ai": "workspace:*",
        "@gooddata/sdk-ui-geo": "workspace:*",
        "@gooddata/sdk-ui-kit": "workspace:*",
        "@gooddata/sdk-ui-loaders": "workspace:*",
        "@gooddata/sdk-ui-pivot": "workspace:*",
        "lodash-es": "^4.17.23",
        "react-intl": "7.1.11",
        "ts-invariant": "0.10.3",
        "tslib": "2.8.1",
        "uuid": "11.1.1"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@gooddata/sdk-backend-mockingbird": "workspace:*",
        "@microsoft/api-documenter": "^7.17.0",
        "@microsoft/api-extractor": "^7.55.2",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "24.12.0",
        "@types/raf": "^3.4.0",
        "@types/react": "19.1.11",
        "@types/react-dom": "19.1.7",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "@vitest/eslint-plugin": "1.6.19",
        "dependency-cruiser": "17.3.10",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-esm": "1.2.1",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "raf": "3.4.1",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "rolldown": "1.0.3",
        "rollup": "^4.51.0",
        "typescript": "5.9.3",
        "vite": "8.0.16",
        "vite-plugin-css-injected-by-js": "3.1.1",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    }
}
