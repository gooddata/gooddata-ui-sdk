{
    "name": "@gooddata/sdk-ui-tests-e2e",
    "version": "1.0.0",
    "private": true,
    "description": "GoodData SDK e2e tests",
    "license": "LicenseRef-LICENSE",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "libs/sdk-ui-tests-e2e"
    },
    "files": [
        "dist/**/*.js",
        "dist/**/*.json",
        "dist/**/*.d.ts",
        "dist/**/*.map",
        "dist/**/*.svg",
        "esm/**/*.js",
        "esm/**/*.json",
        "esm/**/*.d.ts",
        "esm/**/*.map",
        "esm/**/*.svg",
        "styles"
    ],
    "type": "module",
    "sideEffects": [
        "*.css",
        "*.svg"
    ],
    "main": "dist/index.js",
    "module": "esm/index.js",
    "browser": "dist/index.js",
    "typings": "esm/index.d.ts",
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:validate": "npm run validate",
        "build": "tsgo",
        "clean": "../../common/scripts/clean-command-state.sh && rm -rf ci coverage *.log",
        "local-dev-test-visual": "node ./scripts/run_local_dev_isolated.js",
        "local-dev-test-visual-recordings": "node ./scripts/run_local_dev_isolated.js --with-recordings",
        "local-dev-wiremock": "node ./scripts/run_local_dev_wiremock.js",
        "local-dev-wiremock-proxy": "node ./scripts/run_local_dev_wiremock.js --proxy",
        "local-dev-wiremock-proxy-verbose": "node ./scripts/run_local_dev_wiremock.js --proxy --verbose",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "run-integrated": "node ./scripts/run_integrated.js",
        "run-isolated": "./scripts/run_isolated.sh",
        "run-isolated-record": "MODE=record ./scripts/run_isolated.sh",
        "validate": "npm run lint && npm run format-check",
        "lint": "oxlint . --type-aware --quiet && eslint .",
        "lint-fix": "oxlint . --type-aware --quiet --fix && eslint . --fix"
    },
    "devDependencies": {
        "@gooddata/e2e-utils": "workspace:*",
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-ui-tests-app": "workspace:*",
        "@gooddata/sdk-ui-tests-reference-workspace": "workspace:*",
        "@gooddata/util": "workspace:*",
        "@playwright/test": "1.58.2",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "22.13.0",
        "@types/pdf-parse": "^1.1.1",
        "@typescript-eslint/eslint-plugin": "8.52.0",
        "@typescript-eslint/parser": "8.52.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "axios": "^1.9.0",
        "dotenv": "16.4.5",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-chai-friendly": "1.1.0",
        "eslint-plugin-cypress": "3.6.0",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "lodash-es": "^4.17.23",
        "node-xlsx": "0.24.0",
        "oxfmt": "0.27.0",
        "oxlint": "^1.43.0",
        "oxlint-tsgolint": "0.11.4",
        "pdf-parse": "1.1.4",
        "typescript": "5.9.3"
    },
    "dependenciesInfo": "This is package is SDK tool and is not distributed all dependencies must be defined as devDependencies due to FOSSA automated report generation"
}
