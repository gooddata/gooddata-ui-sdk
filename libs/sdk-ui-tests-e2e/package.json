{
    "name": "@gooddata/sdk-ui-tests-e2e",
    "version": "11.37.0-alpha.5",
    "private": true,
    "description": "GoodData SDK e2e tests",
    "license": "LicenseRef-LICENSE",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "libs/sdk-ui-tests-e2e"
    },
    "type": "module",
    "sideEffects": [
        "*.css",
        "*.svg"
    ],
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:pack-build": "tar -czf sdk-ui-tests-e2e.tgz -C dist .",
        "_phase:publish-test-docker-images": "bash ../../../common/scripts/docker/publish-test-docker-image.sh",
        "_phase:validate": "npm run validate",
        "build": "npm-run-all -p build-check dist",
        "build-check": "tsgo",
        "clean": "../../common/scripts/clean-command-state.sh && rm -rf ci coverage *.log",
        "dist": "rm -rf dist && NODE_NO_WARNINGS=1 rolldown build --config rolldown.config.ts",
        "e2e:integrated:docker": "./scripts/local/run.sh integrated docker",
        "e2e:integrated:local": "./scripts/local/run.sh integrated local",
        "e2e:isolated:docker:proxy": "./scripts/local/run.sh isolated docker proxy",
        "e2e:isolated:docker:record": "./scripts/local/run.sh isolated docker record",
        "e2e:isolated:docker:replay": "./scripts/local/run.sh isolated docker replay",
        "e2e:isolated:local:proxy": "./scripts/local/run.sh isolated local proxy",
        "e2e:isolated:local:record": "./scripts/local/run.sh isolated local record",
        "e2e:isolated:local:replay": "./scripts/local/run.sh isolated local replay",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --type-aware --quiet && eslint .",
        "lint-fix": "oxlint . --type-aware --quiet --fix && eslint . --fix",
        "validate": "npm run lint && npm run format-check"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@gooddata/sdk-e2e-utils": "workspace:*",
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-ui-tests-app": "workspace:*",
        "@gooddata/sdk-ui-tests-reference-workspace": "workspace:*",
        "@gooddata/util": "workspace:*",
        "@playwright/test": "1.60.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "24.12.0",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "axios": "1.13.5",
        "dotenv": "16.4.5",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-chai-friendly": "1.1.0",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-playwright": "2.10.1",
        "eslint-plugin-sonarjs": "3.0.6",
        "lodash-es": "^4.17.23",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.45.0",
        "oxlint": "^1.43.0",
        "oxlint-tsgolint": "0.11.4",
        "rolldown": "1.0.0-rc.9",
        "typescript": "5.9.3"
    },
    "dependenciesInfo": "This is package is SDK tool and is not distributed all dependencies must be defined as devDependencies due to FOSSA automated report generation"
}
