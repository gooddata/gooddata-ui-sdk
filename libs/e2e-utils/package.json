        "eslint-plugin-playwright": "2.10.1",
        "eslint-plugin-regexp": "1.15.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "eslint-plugin-tsdoc": "0.2.14",
        "jiti": "2.6.1",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.27.0",
        "oxlint": "^1.43.0",
        "oxlint-tsgolint": "0.11.4",
        "typescript": "5.9.3"
    }
