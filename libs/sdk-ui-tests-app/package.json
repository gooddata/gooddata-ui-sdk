{
    "name": "@gooddata/sdk-ui-tests-app",
    "version": "11.42.0-alpha.4",
    "private": true,
    "description": "GoodData SDK e2e tests",
    "license": "LicenseRef-LICENSE",
    "author": "GoodData Corporation",
    "repository": {
        "type": "git",
        "url": "https://github.com/gooddata/gooddata-ui-sdk.git",
        "directory": "libs/sdk-ui-tests-e2e"
    },
    "type": "module",
    "main": "index.html",
    "scripts": {
        "_phase:build": "npm run build",
        "_phase:pack-build": "tar -czf sdk.tgz -C dist .",
        "_phase:publish-test-docker-images": "bash ../../../common/scripts/docker/publish-test-docker-image.sh",
        "_phase:validate": "npm run validate",
        "build": "npm-run-all -p dist build-check",
        "build-check": "tsgo",
        "clean": "../../common/scripts/clean-command-state.sh && rm -rf dist *.log",
        "dep-cruiser": "depcruise --validate .dependency-cruiser.js --output-type err-long src/",
        "dev": "vite --force",
        "dist": "rm -rf dist && export NODE_OPTIONS=\"--max_old_space_size=4096\" && vite build",
        "format-check": "oxfmt --check .",
        "format-write": "oxfmt .",
        "lint": "oxlint . --quiet && eslint .",
        "lint-fix": "oxlint . --quiet --fix && eslint . --fix",
        "validate": "npm run lint && npm run dep-cruiser && npm run format-check"
    },
    "devDependencies": {
        "@gooddata/eslint-config": "workspace:*",
        "@gooddata/oxlint-config": "workspace:*",
        "@gooddata/sdk-backend-base": "workspace:*",
        "@gooddata/sdk-backend-spi": "workspace:*",
        "@gooddata/sdk-backend-tiger": "workspace:*",
        "@gooddata/sdk-model": "workspace:*",
        "@gooddata/sdk-ui": "workspace:*",
        "@gooddata/sdk-ui-charts": "workspace:*",
        "@gooddata/sdk-ui-dashboard": "workspace:*",
        "@gooddata/sdk-ui-ext": "workspace:*",
        "@gooddata/sdk-ui-filters": "workspace:*",
        "@gooddata/sdk-ui-geo": "workspace:*",
        "@gooddata/sdk-ui-kit": "workspace:*",
        "@gooddata/sdk-ui-pivot": "workspace:*",
        "@gooddata/sdk-ui-tests-reference-workspace": "workspace:*",
        "@gooddata/sdk-ui-web-components": "workspace:*",
        "@types/react": "19.1.11",
        "@types/react-dom": "19.1.7",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260202.1",
        "@vitejs/plugin-react": "6.0.2",
        "core-js": "3.45.1",
        "dependency-cruiser": "17.3.10",
        "dotenv": "16.4.5",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "npm-run-all": "^4.1.5",
        "oxfmt": "0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "rolldown": "1.0.3",
        "sass": "1.70.0",
        "typescript": "5.9.3",
        "vite": "8.0.16"
    },
    "dependenciesInfo": "This is package is SDK tool and is not distributed all dependencies must be defined as devDependencies due to FOSSA automated report generation"
}
